# .env.example - example environment variables for MySQL toko_db container
#
# Copy this file to .env and adjust the values as needed.
#
# MySQL administrative credentials
MYSQL_ROOT_PASSWORD=secret          # Root password (change in production)
#
# Database configuration
MYSQL_DATABASE=shop_application    # Initial database name
MYSQL_USER=toko_user               # Regular user name
MYSQL_PASSWORD=toko_pass           # Regular user password
#
# Runtime configuration
CONTAINER_NAME=toko_db             # Docker container name
MYSQL_PORT=3306                    # MySQL service port